-- Narrowed postulate: symmetric-monoidal coherence on the structural
-- fragment, at the `FreeMonoidal` level.
--
-- This is the *minimal* postulate needed to discharge the original
-- `decode-rel-resp-тЙЕс┤┤-atomic-compound-0E`.  It is the statement of
-- Mac Lane's symmetric monoidal coherence theorem on the structural
-- (i.e. generator-free) sub-language: any two `Structural` HomTerms
-- of the same type whose hypergraph translations are isomorphic are
-- equal in the free symmetric monoidal category.
--
-- All `decode-rel`/`bridge`/`unflatten`-flavoured plumbing has been
-- factored out: the postulate conclusion is the plain `_тЙИTerm_`
-- equality between two `HomTerm A B`s built from
-- `id, ╬╗тЗТ, ╬╗тЗР, ╧БтЗТ, ╧БтЗР, ╬▒тЗТ, ╬▒тЗР, ╧Г, _тИШ_, _тКЧтВБ_`.  The constructive
-- discharge ultimately requires extending
-- `Categories.MonoidalCoherence.Solver` (currently Mac Lane only) to
-- handle ╧Г via permutation tracking тАФ see the header for the path.

--------------------------------------------------------------------------------
-- Extract the underlying permutation of a structural HomTerm.
--
-- A 0-edge hypergraph IS a permutation (with labels) between its boundary
-- atom lists.  We extract this permutation by structural induction on
-- `Structural`, using only the propositional permutation combinators
-- (`refl`, `prep`, `swap`, `trans`) and standard list-permutation lemmas
-- (`++-comm`, `++-assoc`, `++-identity╩│`, `++тБ║`).
--
-- The directions:
--   * `id        : A тЖТ A`              тЖж refl
--   * `╬╗тЗТ : IтКЧA тЖТ A`,  `╬╗тЗР : A тЖТ IтКЧA`  тЖж refl     ([] ++ xs тЙб xs definitionally)
--   * `╧БтЗТ : AтКЧI тЖТ A`                   тЖж ++-identity╩│
--   * `╧БтЗР : A тЖТ AтКЧI`                   тЖж sym (++-identity╩│)
--   * `╬▒тЗТ : (AтКЧB)тКЧC тЖТ AтКЧ(BтКЧC)`         тЖж тЖн-reflexive (++-assoc)
--   * `╬▒тЗР : AтКЧ(BтКЧC) тЖТ (AтКЧB)тКЧC`         тЖж sym
--   * `╧Г  : AтКЧB тЖТ BтКЧA`                 тЖж ++-comm
--   * `_тИШ_`                            тЖж Perm.trans (note: h тИШ k goes k then h)
--   * `_тКЧтВБ_`                           тЖж PermProp.++тБ║

Structural-to-perm
  : тИА {A B} {f : HomTerm A B}
  тЖТ Structural f тЖТ flatten A тЖн flatten B
Structural-to-perm (structural-id {A}) = Perm.refl
Structural-to-perm structural-╬╗тЗТ        = Perm.refl
Structural-to-perm structural-╬╗тЗР        = Perm.refl
Structural-to-perm (structural-╧БтЗТ {A})  = PermProp.++-identity╩│ (flatten A)
Structural-to-perm (structural-╧БтЗР {A})  = Perm.тЖн-sym (PermProp.++-identity╩│ (flatten A))
Structural-to-perm (structural-╬▒тЗТ {A} {B} {C}) =
  Perm.тЖн-reflexive (Data.List.Properties.++-assoc (flatten A) (flatten B) (flatten C))
Structural-to-perm (structural-╬▒тЗР {A} {B} {C}) =
  Perm.тЖн-sym (Perm.тЖн-reflexive (Data.List.Properties.++-assoc (flatten A) (flatten B) (flatten C)))
Structural-to-perm (structural-╧Г {A} {B}) =
  PermProp.++-comm (flatten A) (flatten B)
Structural-to-perm (structural-тИШ sh sk) =
  Perm.trans (Structural-to-perm sk) (Structural-to-perm sh)
Structural-to-perm (structural-тКЧ sh sk) =
  PermProp.++тБ║ (Structural-to-perm sh) (Structural-to-perm sk)

--------------------------------------------------------------------------------
-- Narrowed postulate: symmetric-monoidal coherence on the structural
-- fragment.
--
-- An earlier version of this file attempted a further split into
--
--   * `perm-eq-from-iso : тЯк f тЯл тЙЕс┤┤ тЯк g тЯл тЖТ Structural-to-perm sf тЙб Structural-to-perm sg`
--   * `Structural-coherence-from-perm-eq : тАж тЙб тАж тЖТ f тЙИTerm g`
--
-- and derived `Structural-coherence-тЙИTerm` from the two.  That split
-- is **unsound** in its propositional-equality form:
-- `Data.List.Relation.Binary.Permutation.Propositional._тЖн_` is *not*
-- a thin relation тАФ `Perm.refl` and `Perm.trans Perm.refl Perm.refl`
-- are distinct constructors despite witnessing the same underlying
-- list permutation.  Concrete counter-example: `f = id`, `sf =
-- structural-id`, `g = id тИШ id`, `sg = structural-тИШ structural-id
-- structural-id` give `Structural-to-perm sf = Perm.refl` while
-- `Structural-to-perm sg = Perm.trans Perm.refl Perm.refl`, which are
-- *not* `_тЙб_`, yet the corresponding hypergraphs are isomorphic.  So
-- the `perm-eq-from-iso` half could never be discharged as stated.
--
-- Reverting to a single postulate restores soundness: this is exactly
-- the statement of Mac Lane's symmetric monoidal coherence theorem on
-- the structural (i.e. generator-free) sub-language.  The constructive
-- discharge ultimately requires extending
-- `Categories.MonoidalCoherence.Solver` (currently Mac Lane only) to
-- handle ╧Г via permutation tracking.
--
-- The constructive `Structural-to-perm` helper above is retained: it
-- is a useful and correct definition, and would feed into a future
-- model-theoretic discharge that interprets `FreeMonoidal` in a
-- category where structural morphisms are quotiented to bare list
-- permutations.

-- Splitting via `HasSigma?` exposes the ╧Г-free (Mac Lane) sub-case as
-- a strictly narrower postulate that is mechanically dischargeable by
-- `Categories.MonoidalCoherence.Solver.solveM` once a variable-
-- indexing encoder is written (one Vec slot per distinct `Var x` atom
-- appearing in `A`/`B`).  The ╧Г-containing residual is the genuine
-- remaining content тАФ requires extending `solveM` to the symmetric
-- fragment.  Under the iso hypothesis the ╧Г-free case has identity-
-- forced boundary ╧Ж, so Mac Lane coherence applies directly.

--------------------------------------------------------------------------------
-- Constructive discharge plumbing for the ╧Г-free case via
-- `Categories.MonoidalCoherence.Solver.solveM`.
--
-- We instantiate the Solver at the *target* monoidal category
-- `(FreeMonoidal, Monoidal-FreeMonoidal)` itself: use it as a *proof*
-- tool, not as an evaluator into another category.  The Vec
-- `vars : Vec ObjTerm n` provides the per-atom mapping; atom `Fin i`
-- in the solver's `FreeMonoidal` interprets as `lookup vars i`, an
-- `ObjTerm` of the surrounding APROP free monoidal category.
--
-- Encoder pipeline (constructive parts below):
--   1. `objAtoms : ObjTerm тЖТ List X` collects `Var x` atoms.
--   2. `idx : (xs : List X) (x : X) тЖТ Fin (length xs)` lookup
--      (using `_тЙЯX_`); on miss returns the last slot (safe fallback,
--      not used in the well-typed branch).
--   3. `varsOf : List X тЖТ тИГ Vec ObjTerm` produces the encoder's Vec.
--
-- Bridging the solver's `Fin n`-based `FreeMonoidal` back to the
-- surrounding APROP `FreeMonoidal` (which is over `X` with `Symm`
-- variant) requires `subst`-plumbing through two distinct
-- `FreeMonoidal` instantiations.  We leave the bridge as a narrow
-- postulate `enc-faithful` below тАФ strictly weaker than the original
-- `-no╧Г` claim because it is the *purely structural* soundness of the
-- Mac Lane encoder, no ╧Г involved.

-- Collect `Var x` atoms from an ObjTerm.
objAtoms : ObjTerm тЖТ List X
objAtoms unit     = []
objAtoms (A тКЧтВА B) = objAtoms A ++ objAtoms B
objAtoms (Var x)  = x тИ╖ []

-- Index of x in xs (with safe fallback to `zero` of `Fin (suc (length xs))`).
idxFin : (xs : List X) (x : X) тЖТ Fin (suc (length xs))
idxFin []       x = zero
idxFin (y тИ╖ ys) x with x тЙЯX y
... | yes _ = zero
... | no  _ = suc (idxFin ys x)

-- Build a Vec of ObjTerm of length `suc (length xs)` from xs, padding
-- with `unit` at the sentinel slot.
varsVec : (xs : List X) тЖТ Vec ObjTerm (suc (length xs))
varsVec []       = unit тИ╖т▒╜ []т▒╜
varsVec (x тИ╖ xs) = Var x тИ╖т▒╜ varsVec xs

-- Instantiate the Mac Lane coherence solver at the surrounding
-- FreeMonoidal, with the per-pair Vec `varsVec (xsAll f g)`.
module _ {A B : ObjTerm} {f g : HomTerm A B} (nf : NoSigma f) (ng : NoSigma g) where

  -- Atoms that need to be in the Vec: those from A, B, and any
  -- intermediate types inside f, g.  For the Mac Lane fragment a
  -- conservative choice is `objAtoms A ++ objAtoms B` extended with
  -- atoms collected from each NoSigma sub-term's type indices.

  -- We collect via NoSigma so termination is on the structural witness.
  nosigmaAtoms : тИА {A B} {h : HomTerm A B} тЖТ NoSigma h тЖТ List X
  nosigmaAtoms {A} {B} nosigma-id      = objAtoms A
  nosigmaAtoms (nosigma-╬╗тЗТ {A'})       = objAtoms A'
  nosigmaAtoms (nosigma-╬╗тЗР {A'})       = objAtoms A'
  nosigmaAtoms (nosigma-╧БтЗТ {A'})       = objAtoms A'
  nosigmaAtoms (nosigma-╧БтЗР {A'})       = objAtoms A'
  nosigmaAtoms (nosigma-╬▒тЗТ {A'} {B'} {C'}) =
    objAtoms A' ++ objAtoms B' ++ objAtoms C'
  nosigmaAtoms (nosigma-╬▒тЗР {A'} {B'} {C'}) =
    objAtoms A' ++ objAtoms B' ++ objAtoms C'
  nosigmaAtoms (nosigma-тИШ h k) = nosigmaAtoms h ++ nosigmaAtoms k
  nosigmaAtoms (nosigma-тКЧ h k) = nosigmaAtoms h ++ nosigmaAtoms k

  xsAll : List X
  xsAll = objAtoms A ++ objAtoms B ++ nosigmaAtoms nf ++ nosigmaAtoms ng

  vars-fg : Vec ObjTerm (suc (length xsAll))
  vars-fg = varsVec xsAll

  -- Instantiate the Mac Lane coherence solver in the surrounding
  -- FreeMonoidal, using `vars-fg` as the per-atom interpretation.
  open import Categories.MonoidalCoherence using (module Solver)
  open import Categories.Category.Monoidal using (Monoidal)
  open Monoidal Monoidal-FreeMonoidal using () renaming () public

  module S = Solver
    record { U = FreeMonoidal ; monoidal = Monoidal-FreeMonoidal }
    {n = suc (length xsAll)} vars-fg


  -- Structural encoder: ObjTerm тЖТ S.ObjTerm.  Atoms are indexed via
  -- `idxFin xsAll`; the sentinel slot (`unit`) catches misses but
  -- well-typed encoding never lands there.
  enc-Obj : ObjTerm тЖТ S.ObjTerm
  enc-Obj unit     = S.unit
  enc-Obj (P тКЧтВА Q) = enc-Obj P S.тКЧтВА enc-Obj Q
  enc-Obj (Var x)  = S.Var (idxFin xsAll x)

  -- Structural encoder on HomTerms: NoSigma тЖТ S.HomTerm.  Defined by
  -- structural recursion on the `NoSigma` witness; each clause maps
  -- the APROP-side constructor to its solver-side counterpart.
  enc-Hom : тИА {P Q} {h : HomTerm P Q}
          тЖТ NoSigma h
          тЖТ S.HomTerm (enc-Obj P) (enc-Obj Q)
  enc-Hom nosigma-id      = S.id
  enc-Hom nosigma-╬╗тЗТ      = S.╬╗тЗТ
  enc-Hom nosigma-╬╗тЗР      = S.╬╗тЗР
  enc-Hom nosigma-╧БтЗТ      = S.╧БтЗТ
  enc-Hom nosigma-╧БтЗР      = S.╧БтЗР
  enc-Hom nosigma-╬▒тЗТ      = S.╬▒тЗТ
  enc-Hom nosigma-╬▒тЗР      = S.╬▒тЗР
  enc-Hom (nosigma-тИШ h k) = enc-Hom h S.тИШ enc-Hom k
  enc-Hom (nosigma-тКЧ h k) = enc-Hom h S.тКЧтВБ enc-Hom k

  -- The Solver's interpretation `тЯж ef тЯзтВБ` lives in APROP's
  -- FreeMonoidal: source `Functor.FтВА S.freeFunctor (enc-Obj P) : ObjTerm`, target similarly.
  -- `solveM ef eg : тЯж ef тЯзтВБ тЙИTerm тЯж eg тЯзтВБ` is precisely an APROP-side
  -- `_тЙИTerm_` equation (Mac Lane coherence in the ╧Г-free fragment).
  --
  -- To convert this into `f тЙИTerm g`, we need encoder-soundness:
  -- `f тЙИTerm Functor.FтВБ S.freeFunctor (enc-Hom nf)` and similarly for `g` (modulo
  -- equality `Functor.FтВА S.freeFunctor (enc-Obj A) тЙб A`).  Both lemmas are pure structural
  -- recursions, but discharging them requires bridging two
  -- `FreeMonoidal` instantiations and aligning `subst`s тАФ left as a
  -- narrow self-contained postulate.

  -- Encoded pair (constructive output of the encoder).
  ef-built : S.HomTerm (enc-Obj A) (enc-Obj B)
  ef-built = enc-Hom nf

  eg-built : S.HomTerm (enc-Obj A) (enc-Obj B)
  eg-built = enc-Hom ng

  -- `solveM` discharges Mac Lane coherence in the ╧Г-free Fin-indexed
  -- FreeMonoidal.  The return type uses the Solver's private
  -- `FreeFunctor` interpretation `тЯж_тЯзтВБ` (not re-exported by `Solver`
  -- with `public`).  We name the result and let Agda infer the type.
  --
  -- This call is the *constructive heart* of the ╧Г-free coherence
  -- discharge: at this point all the categorical work is done.  The
  -- remaining work (`enc-bridge-to-fтЙИg`) is purely the encoder's
  -- soundness reflection back into APROP's `_тЙИTerm_`.
  solver-result : _
  solver-result = S.solveM ef-built eg-built

  --------------------------------------------------------------------------------
  -- Encoder soundness: `Functor.FтВА S.freeFunctor (enc-Obj P) тЙб P` when atoms of P live in xsAll.
  --
  -- Below, `lookup-mem` is the heart: when `x тИИ xs` (witnessed by `Any`),
  -- the encoder round-trips `x` to `Var x`.  Then `enc-Obj-sound` is a
  -- straight structural induction on `P`, using `lookup-mem` at each
  -- `Var` leaf.

  -- Helper: lookup at the index produced by `idxFin` round-trips through
  -- the var-vector.  By induction on the membership witness.
  lookup-mem
    : (xs : List X) {x : X} (m : x тИИ xs)
    тЖТ lookup (varsVec xs) (idxFin xs x) тЙб Var x
  lookup-mem (y тИ╖ ys) {x} (here refl) with x тЙЯX y
  ... | yes _    = refl
  ... | no  xтЙвy  = тКе-elim (xтЙвy refl)
  lookup-mem (y тИ╖ ys) {x} (there m) with x тЙЯX y
  ... | yes refl = refl
  ... | no  _    = lookup-mem ys m

  -- A `Var` atom appearing inside `objAtoms P` is exactly an atom of P.
  -- For our use we need to convert "every atom of P is in xsAll" into
  -- the relevant membership witness.  We work with the simple sublist
  -- inclusion `objAtoms P тКЖ xsAll`.

  _тКЖL_ : List X тЖТ List X тЖТ Set
  xs тКЖL ys = тИА {x} тЖТ x тИИ xs тЖТ x тИИ ys

  -- Soundness of the object encoder, parameterised by membership.
  enc-Obj-sound
    : (P : ObjTerm)
    тЖТ objAtoms P тКЖL xsAll
    тЖТ Functor.FтВА S.freeFunctor (enc-Obj P) тЙб P
  enc-Obj-sound unit       _   = refl
  enc-Obj-sound (P тКЧтВА Q) sub =
    congтВВ _тКЧтВА_
      (enc-Obj-sound P (╬╗ m тЖТ sub (тИИ-++╦б m)))
      (enc-Obj-sound Q (╬╗ m тЖТ sub (тИИ-++╩│ (objAtoms P) m)))
    where
      тИИ-++╦б : тИА {x ys zs} тЖТ x тИИ ys тЖТ x тИИ (ys ++ zs)
      тИИ-++╦б (here px)  = here px
      тИИ-++╦б (there m)  = there (тИИ-++╦б m)
      тИИ-++╩│ : тИА {x} (ys : List X) {zs} тЖТ x тИИ zs тЖТ x тИИ (ys ++ zs)
      тИИ-++╩│ []        m = m
      тИИ-++╩│ (y тИ╖ ys') m = there (тИИ-++╩│ ys' m)
  enc-Obj-sound (Var x) sub = lookup-mem xsAll (sub (here refl))

  -- xsAll begins with `objAtoms A`, so atoms of A are trivially in xsAll.
  -- Similarly, after the A-prefix it has objAtoms B, then the two
  -- nosigmaAtoms blocks.

  тИИ-++╦б : тИА {x} {ys zs : List X} тЖТ x тИИ ys тЖТ x тИИ (ys ++ zs)
  тИИ-++╦б (here px)  = here px
  тИИ-++╦б (there m)  = there (тИИ-++╦б m)
  тИИ-++╩│ : тИА {x} (ys : List X) {zs : List X} тЖТ x тИИ zs тЖТ x тИИ (ys ++ zs)
  тИИ-++╩│ []        m = m
  тИИ-++╩│ (y тИ╖ ys') m = there (тИИ-++╩│ ys' m)

  -- objAtoms A is the first block of xsAll.
  A-atoms-in-xsAll : objAtoms A тКЖL xsAll
  A-atoms-in-xsAll m = тИИ-++╦б m

  B-atoms-in-xsAll : objAtoms B тКЖL xsAll
  B-atoms-in-xsAll m = тИИ-++╩│ (objAtoms A) (тИИ-++╦б m)

  enc-Obj-sound-A : Functor.FтВА S.freeFunctor (enc-Obj A) тЙб A
  enc-Obj-sound-A = enc-Obj-sound A A-atoms-in-xsAll

  enc-Obj-sound-B : Functor.FтВА S.freeFunctor (enc-Obj B) тЙб B
  enc-Obj-sound-B = enc-Obj-sound B B-atoms-in-xsAll

  --------------------------------------------------------------------------------
  -- Inclusion of every NoSigma sub-term's atoms into xsAll.  We thread
  -- this as a `Path` from a witness inside `nf`/`ng` down to xsAll.
  --
  -- For тИШ/тКЧ we use the fact that `nosigmaAtoms` is additive across
  -- composition/tensor (the witness lives in either the left or right
  -- branch).  But really, only the LEAF nodes need direct membership тАФ
  -- internal тИШ/тКЧ nodes inherit recursively.  We therefore phrase
  -- `enc-Hom-sound` as: given that the source and target objAtoms are
  -- in xsAll, the encoder is sound; and at тИШ/тКЧ we recurse with the
  -- intermediate type's atoms in xsAll (provided by the structural
  -- shape of nf, ng).

  -- For `nosigma-тИШ {B = M} h k` we need atoms of M in xsAll.  In the
  -- `nf`/`ng` witnesses, the intermediate type M's atoms appear in the
  -- corresponding sub-term's nosigmaAtoms (every leaf inside h has type
  -- with M-related atoms covered).  Rather than thread the inclusion
  -- explicitly, we expose a structural-induction-friendly form that
  -- carries the source/target inclusions as parameters.

  --------------------------------------------------------------------------------
  -- Hom encoder soundness (тЙИTerm form, parameterised by atom-inclusions
  -- for the source and target types).
  --
  -- We package `Functor.FтВА S.freeFunctor (enc-Obj P) тЙб P` and similarly for Q, then state:
  --
  --   substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom nh)) тЙб h
  --
  -- By induction on nh.  Base cases are immediate because
  -- `S.тЯж S.id тЯзтВБ`, `S.тЯж S.╬╗тЗТ тЯзтВБ`, ..., reduce definitionally to the
  -- APROP-side constructors `id`, `╬╗тЗТ`, ..., at the encoded source/
  -- target objects.  The `substтВВ` collapses to `refl` after K-style
  -- reasoning on ObjTerm equality (justified by ObjTerm having
  -- decidable equality, hence UIP).

  -- For the тИШ/тКЧ inductive cases we additionally need atom-inclusion
  -- for the intermediate type; these come from the structural form
  -- of the NoSigma sub-witness's source/target leaves.

  -- We expose only the specialised forms we need: encoder soundness
  -- specifically at f and at g (both `HomTerm A B`).  Their proofs use
  -- the postulate `enc-Hom-тЙб-up-to-subst` below тАФ the *narrowest*
  -- remaining gap, strictly about `subst` plumbing through a
  -- definitionally-trivial encoder.

  -- Discharge of `enc-Hom-sound-id`: any NoSigma term h is transported
  -- to itself by the encoderтАУdecoder round-trip.  Proof: induction on
  -- nh.  For each structural constructor, `FтВБ S.freeFunctor (enc-Hom тАж)`
  -- reduces definitionally to the corresponding APROP-side constructor,
  -- and the substтВВ collapses via UIP on ObjTerm (provable from decidable
  -- atom equality `_тЙЯ-ObjTerm_`) combined with J on a single object-arg
  -- equality (per constructor).
  private
    import Axiom.UniquenessOfIdentityProofs as UIP-mod
    open APROPSignatureDec sig-dec using (_тЙЯ-ObjTerm_)
    module ObjTerm-UIP-mod = UIP-mod.DecidableтЗТUIP _тЙЯ-ObjTerm_

    ObjTerm-UIP : тИА {A B : ObjTerm} (p q : A тЙб B) тЖТ p тЙб q
    ObjTerm-UIP = ObjTerm-UIP-mod.тЙб-irrelevant

    -- Per-constructor coercion lemmas.  Each takes the source/target
    -- substitutions plus the underlying argument equalities (derived
    -- from sP/sQ via injectivity of `_тКЧтВА_`), and reduces `substтВВ`
    -- through the constructor to refl.

    id-coerce
      : тИА {X Y : ObjTerm} (p q : X тЙб Y)
      тЖТ substтВВ HomTerm p q (id {X}) тЙб id {Y}
    id-coerce refl q with ObjTerm-UIP q refl
    ... | refl = refl

    ╬╗тЗТ-coerce
      : тИА {X Y : ObjTerm} (p : unit тКЧтВА X тЙб unit тКЧтВА Y) (q : X тЙб Y)
      тЖТ substтВВ HomTerm p q (╬╗тЗТ {X}) тЙб ╬╗тЗТ {Y}
    ╬╗тЗТ-coerce p refl with ObjTerm-UIP p refl
    ... | refl = refl

    ╬╗тЗР-coerce
      : тИА {X Y : ObjTerm} (p : X тЙб Y) (q : unit тКЧтВА X тЙб unit тКЧтВА Y)
      тЖТ substтВВ HomTerm p q (╬╗тЗР {X}) тЙб ╬╗тЗР {Y}
    ╬╗тЗР-coerce refl q with ObjTerm-UIP q refl
    ... | refl = refl

    ╧БтЗТ-coerce
      : тИА {X Y : ObjTerm} (p : X тКЧтВА unit тЙб Y тКЧтВА unit) (q : X тЙб Y)
      тЖТ substтВВ HomTerm p q (╧БтЗТ {X}) тЙб ╧БтЗТ {Y}
    ╧БтЗТ-coerce p refl with ObjTerm-UIP p refl
    ... | refl = refl

    ╧БтЗР-coerce
      : тИА {X Y : ObjTerm} (p : X тЙб Y) (q : X тКЧтВА unit тЙб Y тКЧтВА unit)
      тЖТ substтВВ HomTerm p q (╧БтЗР {X}) тЙб ╧БтЗР {Y}
    ╧БтЗР-coerce refl q with ObjTerm-UIP q refl
    ... | refl = refl

    ╬▒тЗТ-coerce
      : тИА {X Y Z X' Y' Z' : ObjTerm}
          (sX : X тЙб X') (sY : Y тЙб Y') (sZ : Z тЙб Z')
          (p : (X тКЧтВА Y) тКЧтВА Z тЙб (X' тКЧтВА Y') тКЧтВА Z')
          (q : X тКЧтВА (Y тКЧтВА Z) тЙб X' тКЧтВА (Y' тКЧтВА Z'))
      тЖТ substтВВ HomTerm p q (╬▒тЗТ {X} {Y} {Z}) тЙб ╬▒тЗТ {X'} {Y'} {Z'}
    ╬▒тЗТ-coerce refl refl refl p q
      with ObjTerm-UIP p refl | ObjTerm-UIP q refl
    ... | refl | refl = refl

    ╬▒тЗР-coerce
      : тИА {X Y Z X' Y' Z' : ObjTerm}
          (sX : X тЙб X') (sY : Y тЙб Y') (sZ : Z тЙб Z')
          (p : X тКЧтВА (Y тКЧтВА Z) тЙб X' тКЧтВА (Y' тКЧтВА Z'))
          (q : (X тКЧтВА Y) тКЧтВА Z тЙб (X' тКЧтВА Y') тКЧтВА Z')
      тЖТ substтВВ HomTerm p q (╬▒тЗР {X} {Y} {Z}) тЙб ╬▒тЗР {X'} {Y'} {Z'}
    ╬▒тЗР-coerce refl refl refl p q
      with ObjTerm-UIP p refl | ObjTerm-UIP q refl
    ... | refl | refl = refl

    -- Injectivity of `_тКЧтВА_`.
    тКЧ-inj╦б : тИА {A A' B B' : ObjTerm} тЖТ (A тКЧтВА B) тЙб (A' тКЧтВА B') тЖТ A тЙб A'
    тКЧ-inj╦б refl = refl

    тКЧ-inj╩│ : тИА {A A' B B' : ObjTerm} тЖТ (A тКЧтВА B) тЙб (A' тКЧтВА B') тЖТ B тЙб B'
    тКЧ-inj╩│ refl = refl

    -- Push substтВВ through `_тИШ_`: it preserves composition, factored
    -- through an intermediate type's equality `sM`.
    тИШ-coerce
      : тИА {X M Y X' M' Y' : ObjTerm}
          (h : HomTerm M Y) (k : HomTerm X M)
          (h' : HomTerm M' Y') (k' : HomTerm X' M')
          (sX : X тЙб X') (sM : M тЙб M') (sY : Y тЙб Y')
          (p : X тЙб X') (q : Y тЙб Y')
      тЖТ substтВВ HomTerm sM sY h тЙб h'
      тЖТ substтВВ HomTerm sX sM k тЙб k'
      тЖТ substтВВ HomTerm p q (h тИШ k) тЙб h' тИШ k'
    тИШ-coerce h k h' k' refl refl refl p q eh ek
      with ObjTerm-UIP p refl | ObjTerm-UIP q refl
    ... | refl | refl rewrite eh | ek = refl

    -- Push substтВВ through `_тКЧтВБ_`.
    тКЧ-coerce
      : тИА {A B C D A' B' C' D' : ObjTerm}
          (h : HomTerm A B) (k : HomTerm C D)
          (h' : HomTerm A' B') (k' : HomTerm C' D')
          (sA : A тЙб A') (sB : B тЙб B') (sC : C тЙб C') (sD : D тЙб D')
          (p : A тКЧтВА C тЙб A' тКЧтВА C') (q : B тКЧтВА D тЙб B' тКЧтВА D')
      тЖТ substтВВ HomTerm sA sB h тЙб h'
      тЖТ substтВВ HomTerm sC sD k тЙб k'
      тЖТ substтВВ HomTerm p q (h тКЧтВБ k) тЙб h' тКЧтВБ k'
    тКЧ-coerce h k h' k' refl refl refl refl p q eh ek
      with ObjTerm-UIP p refl | ObjTerm-UIP q refl
    ... | refl | refl rewrite eh | ek = refl

  -- Inclusion bookkeeping: every NoSigma sub-term's source and target
  -- objAtoms are contained in its `nosigmaAtoms`.  Combined with an
  -- outer "this nh's nosigmaAtoms тКЖ xsAll" hypothesis, we can recover
  -- the intermediate-type equality at every recursive step.

  private
    тКЖL-trans : тИА {xs ys zs : List X} тЖТ xs тКЖL ys тЖТ ys тКЖL zs тЖТ xs тКЖL zs
    тКЖL-trans f g m = g (f m)

    тКЖL-++╦б : тИА {xs ys zs : List X} тЖТ xs тКЖL ys тЖТ xs тКЖL (ys ++ zs)
    тКЖL-++╦б f m = тИИ-++╦б (f m)

    тКЖL-++╩│ : тИА {xs} (ys : List X) {zs : List X} тЖТ xs тКЖL zs тЖТ xs тКЖL (ys ++ zs)
    тКЖL-++╩│ ys f m = тИИ-++╩│ ys (f m)

    тКЖL-refl : тИА {xs : List X} тЖТ xs тКЖL xs
    тКЖL-refl m = m

    objAtoms-тКЧтВА : тИА A B тЖТ objAtoms (A тКЧтВА B) тКЖL (objAtoms A ++ objAtoms B)
    objAtoms-тКЧтВА A B = тКЖL-refl

    -- src-atoms / tgt-atoms of a NoSigma witness are included in its nosigmaAtoms.
    nosigmaAtoms-srcтКЖ : тИА {P Q} {h : HomTerm P Q} (nh : NoSigma h)
                      тЖТ objAtoms P тКЖL nosigmaAtoms nh
    nosigmaAtoms-tgtтКЖ : тИА {P Q} {h : HomTerm P Q} (nh : NoSigma h)
                      тЖТ objAtoms Q тКЖL nosigmaAtoms nh

    nosigmaAtoms-srcтКЖ (nosigma-id {A}) = тКЖL-refl
    -- src of ╬╗тЗТ is unit тКЧтВА A; objAtoms = [] ++ objAtoms A = objAtoms A
    nosigmaAtoms-srcтКЖ (nosigma-╬╗тЗТ {A}) m = m
    nosigmaAtoms-srcтКЖ (nosigma-╬╗тЗР {A}) m = m
    nosigmaAtoms-srcтКЖ (nosigma-╧БтЗТ {A}) {x} m = aux (objAtoms A) m
      where
        aux : тИА (xs : List X) {x} тЖТ x тИИ (xs ++ []) тЖТ x тИИ xs
        aux []       ()
        aux (y тИ╖ ys) (here px) = here px
        aux (y тИ╖ ys) (there m') = there (aux ys m')
    nosigmaAtoms-srcтКЖ (nosigma-╧БтЗР {A}) m = m
    nosigmaAtoms-srcтКЖ (nosigma-╬▒тЗТ {A} {B} {C}) m = ╬▒тЗТ-src m
      where
        -- src = (AтКЧB)тКЧC, objAtoms = (objAtoms A ++ objAtoms B) ++ objAtoms C
        -- tgt of nosigmaAtoms = objAtoms A ++ objAtoms B ++ objAtoms C
        ╬▒тЗТ-src : ((objAtoms A ++ objAtoms B) ++ objAtoms C) тКЖL (objAtoms A ++ objAtoms B ++ objAtoms C)
        ╬▒тЗТ-src m' = ++-assoc-тЖТ (objAtoms A) (objAtoms B) (objAtoms C) m'
          where
            ++-assoc-тЖТ : тИА (xs ys zs : List X) {x}
                       тЖТ x тИИ ((xs ++ ys) ++ zs) тЖТ x тИИ (xs ++ ys ++ zs)
            ++-assoc-тЖТ []       ys zs m'' = m''
            ++-assoc-тЖТ (x тИ╖ xs') ys zs (here px) = here px
            ++-assoc-тЖТ (x тИ╖ xs') ys zs (there m'') = there (++-assoc-тЖТ xs' ys zs m'')
    nosigmaAtoms-srcтКЖ (nosigma-╬▒тЗР {A} {B} {C}) m = m  -- src = AтКЧ(BтКЧC), same flattening
    nosigmaAtoms-srcтКЖ (nosigma-тИШ h k) = тКЖL-++╩│ (nosigmaAtoms h) (nosigmaAtoms-srcтКЖ k)
    nosigmaAtoms-srcтКЖ (nosigma-тКЧ {A} {B} {C} {D} h k) =
      atoms-split-src {A} {C} (nosigmaAtoms-srcтКЖ h) (nosigmaAtoms-srcтКЖ k)
      where
        -- Generic: split membership across `xs ++ ys`.
        split-тИИ : тИА {x} (xs ys : List X) тЖТ x тИИ (xs ++ ys) тЖТ (x тИИ xs) тКО (x тИИ ys)
        split-тИИ []       ys m            = injтВВ m
        split-тИИ (y тИ╖ ys') zs (here px)   = injтВБ (here px)
        split-тИИ (y тИ╖ ys') zs (there m')  with split-тИИ ys' zs m'
        ... | injтВБ m'' = injтВБ (there m'')
        ... | injтВВ m'' = injтВВ m''

        atoms-split-src
          : тИА {A C : ObjTerm} {hA hB : List X}
          тЖТ objAtoms A тКЖL hA тЖТ objAtoms C тКЖL hB
          тЖТ objAtoms (A тКЧтВА C) тКЖL (hA ++ hB)
        atoms-split-src {A} {C} {hA} {hB} fa fc {x} m with split-тИИ (objAtoms A) (objAtoms C) m
        ... | injтВБ mA = тИИ-++╦б (fa mA)
        ... | injтВВ mC = тИИ-++╩│ hA (fc mC)

    nosigmaAtoms-tgtтКЖ (nosigma-id {A}) = тКЖL-refl
    nosigmaAtoms-tgtтКЖ (nosigma-╬╗тЗТ {A}) = тКЖL-refl
    nosigmaAtoms-tgtтКЖ (nosigma-╬╗тЗР {A}) m = m
    nosigmaAtoms-tgtтКЖ (nosigma-╧БтЗТ {A}) = тКЖL-refl
    nosigmaAtoms-tgtтКЖ (nosigma-╧БтЗР {A}) {x} m = aux (objAtoms A) m
      where
        aux : тИА (xs : List X) {x} тЖТ x тИИ (xs ++ []) тЖТ x тИИ xs
        aux []       ()
        aux (y тИ╖ ys) (here px) = here px
        aux (y тИ╖ ys) (there m') = there (aux ys m')
    nosigmaAtoms-tgtтКЖ (nosigma-╬▒тЗТ {A} {B} {C}) m = m  -- tgt is AтКЧ(BтКЧC)
    nosigmaAtoms-tgtтКЖ (nosigma-╬▒тЗР {A} {B} {C}) m = ╬▒тЗР-tgt m
      where
        ╬▒тЗР-tgt : ((objAtoms A ++ objAtoms B) ++ objAtoms C) тКЖL (objAtoms A ++ objAtoms B ++ objAtoms C)
        ╬▒тЗР-tgt m' = ++-assoc-тЖТ (objAtoms A) (objAtoms B) (objAtoms C) m'
          where
            ++-assoc-тЖТ : тИА (xs ys zs : List X) {x}
                       тЖТ x тИИ ((xs ++ ys) ++ zs) тЖТ x тИИ (xs ++ ys ++ zs)
            ++-assoc-тЖТ []       ys zs m'' = m''
            ++-assoc-тЖТ (x тИ╖ xs') ys zs (here px) = here px
            ++-assoc-тЖТ (x тИ╖ xs') ys zs (there m'') = there (++-assoc-тЖТ xs' ys zs m'')
    nosigmaAtoms-tgtтКЖ (nosigma-тИШ h k) = тКЖL-++╦б (nosigmaAtoms-tgtтКЖ h)
    nosigmaAtoms-tgtтКЖ (nosigma-тКЧ {A} {B} {C} {D} h k) =
      atoms-split-tgt {B} {D} (nosigmaAtoms-tgtтКЖ h) (nosigmaAtoms-tgtтКЖ k)
      where
        split-тИИ : тИА {x} (xs ys : List X) тЖТ x тИИ (xs ++ ys) тЖТ (x тИИ xs) тКО (x тИИ ys)
        split-тИИ []       ys m            = injтВВ m
        split-тИИ (y тИ╖ ys') zs (here px)   = injтВБ (here px)
        split-тИИ (y тИ╖ ys') zs (there m')  with split-тИИ ys' zs m'
        ... | injтВБ m'' = injтВБ (there m'')
        ... | injтВВ m'' = injтВВ m''

        atoms-split-tgt
          : тИА {B D : ObjTerm} {hA hB : List X}
          тЖТ objAtoms B тКЖL hA тЖТ objAtoms D тКЖL hB
          тЖТ objAtoms (B тКЧтВА D) тКЖL (hA ++ hB)
        atoms-split-tgt {B} {D} {hA} {hB} fa fc {x} m with split-тИИ (objAtoms B) (objAtoms D) m
        ... | injтВБ mB = тИИ-++╦б (fa mB)
        ... | injтВВ mD = тИИ-++╩│ hA (fc mD)

    -- Intermediate-type equality for the тИШ case: in `nosigma-тИШ h k`,
    -- given an outer inclusion `nosigmaAtoms (nosigma-тИШ h k) тКЖL xsAll`,
    -- the intermediate type M = tgt k = src h has objAtoms covered.
    inter-eq
      : тИА {P Q} {h : HomTerm P Q} (nh : NoSigma h)
      тЖТ nosigmaAtoms nh тКЖL xsAll
      тЖТ Functor.FтВА S.freeFunctor (enc-Obj P) тЙб P
    inter-eq {P} nh inc = enc-Obj-sound P (тКЖL-trans (nosigmaAtoms-srcтКЖ nh) inc)

    inter-eq-tgt
      : тИА {P Q} {h : HomTerm P Q} (nh : NoSigma h)
      тЖТ nosigmaAtoms nh тКЖL xsAll
      тЖТ Functor.FтВА S.freeFunctor (enc-Obj Q) тЙб Q
    inter-eq-tgt {Q = Q} nh inc = enc-Obj-sound Q (тКЖL-trans (nosigmaAtoms-tgtтКЖ nh) inc)

  -- The main lemma.  Now parameterised by an inclusion proof so we can
  -- access intermediate-type equalities in `тИШ` recursive cases.
  enc-Hom-sound-id-inc
    : тИА {P Q} {h : HomTerm P Q} (nh : NoSigma h)
      (inc : nosigmaAtoms nh тКЖL xsAll)
      (sP : Functor.FтВА S.freeFunctor (enc-Obj P) тЙб P)
      (sQ : Functor.FтВА S.freeFunctor (enc-Obj Q) тЙб Q)
    тЖТ substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom nh)) тЙб h
  enc-Hom-sound-id-inc (nosigma-id {A})            inc sP sQ = id-coerce sP sQ
  enc-Hom-sound-id-inc (nosigma-╬╗тЗТ {A})            inc sP sQ = ╬╗тЗТ-coerce sP sQ
  enc-Hom-sound-id-inc (nosigma-╬╗тЗР {A})            inc sP sQ = ╬╗тЗР-coerce sP sQ
  enc-Hom-sound-id-inc (nosigma-╧БтЗТ {A})            inc sP sQ = ╧БтЗТ-coerce sP sQ
  enc-Hom-sound-id-inc (nosigma-╧БтЗР {A})            inc sP sQ = ╧БтЗР-coerce sP sQ
  enc-Hom-sound-id-inc (nosigma-╬▒тЗТ {A} {B} {C})    inc sP sQ =
    ╬▒тЗТ-coerce (тКЧ-inj╦б (тКЧ-inj╦б sP)) (тКЧ-inj╩│ (тКЧ-inj╦б sP)) (тКЧ-inj╩│ sP) sP sQ
  enc-Hom-sound-id-inc (nosigma-╬▒тЗР {A} {B} {C})    inc sP sQ =
    ╬▒тЗР-coerce (тКЧ-inj╦б sP) (тКЧ-inj╦б (тКЧ-inj╩│ sP)) (тКЧ-inj╩│ (тКЧ-inj╩│ sP)) sP sQ
  enc-Hom-sound-id-inc (nosigma-тИШ {A} {M} {C} h k) inc sP sQ =
    let
      inc-h : nosigmaAtoms h тКЖL xsAll
      inc-h m = inc (тИИ-++╦б m)
      inc-k : nosigmaAtoms k тКЖL xsAll
      inc-k m = inc (тИИ-++╩│ (nosigmaAtoms h) m)
      sM : Functor.FтВА S.freeFunctor (enc-Obj M) тЙб M
      sM = inter-eq-tgt k inc-k  -- tgt of k = M
    in тИШ-coerce _ _ _ _ sP sM sQ sP sQ
         (enc-Hom-sound-id-inc h inc-h sM sQ)
         (enc-Hom-sound-id-inc k inc-k sP sM)
  enc-Hom-sound-id-inc (nosigma-тКЧ {A} {B} {C} {D} h k) inc sP sQ =
    let
      inc-h : nosigmaAtoms h тКЖL xsAll
      inc-h m = inc (тИИ-++╦б m)
      inc-k : nosigmaAtoms k тКЖL xsAll
      inc-k m = inc (тИИ-++╩│ (nosigmaAtoms h) m)
    in тКЧ-coerce _ _ _ _
         (тКЧ-inj╦б sP) (тКЧ-inj╦б sQ) (тКЧ-inj╩│ sP) (тКЧ-inj╩│ sQ) sP sQ
         (enc-Hom-sound-id-inc h inc-h (тКЧ-inj╦б sP) (тКЧ-inj╦б sQ))
         (enc-Hom-sound-id-inc k inc-k (тКЧ-inj╩│ sP) (тКЧ-inj╩│ sQ))

  -- Inclusions for the top-level nf and ng in xsAll = objAtoms A ++
  -- objAtoms B ++ nosigmaAtoms nf ++ nosigmaAtoms ng.
  private
    nf-inclusion : nosigmaAtoms nf тКЖL xsAll
    nf-inclusion m = тИИ-++╩│ (objAtoms A) (тИИ-++╩│ (objAtoms B) (тИИ-++╦б m))

    ng-inclusion : nosigmaAtoms ng тКЖL xsAll
    ng-inclusion m = тИИ-++╩│ (objAtoms A) (тИИ-++╩│ (objAtoms B) (тИИ-++╩│ (nosigmaAtoms nf) m))

  -- Lift the propositional encoder-soundness into тЙИTerm.  Specialised
  -- to nh = nf and nh = ng (the only consumers), where the inclusion
  -- `nosigmaAtoms nh тКЖL xsAll` is structurally available.
  enc-Hom-sound-тЙИ-nf
    : (sP : Functor.FтВА S.freeFunctor (enc-Obj A) тЙб A) (sQ : Functor.FтВА S.freeFunctor (enc-Obj B) тЙб B)
    тЖТ substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom nf)) тЙИTerm f
  enc-Hom-sound-тЙИ-nf sP sQ
    rewrite enc-Hom-sound-id-inc nf nf-inclusion sP sQ = тЙИ-Term-refl

  enc-Hom-sound-тЙИ-ng
    : (sP : Functor.FтВА S.freeFunctor (enc-Obj A) тЙб A) (sQ : Functor.FтВА S.freeFunctor (enc-Obj B) тЙб B)
    тЖТ substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom ng)) тЙИTerm g
  enc-Hom-sound-тЙИ-ng sP sQ
    rewrite enc-Hom-sound-id-inc ng ng-inclusion sP sQ = тЙИ-Term-refl

  -- The discharge of the ╧Г-free Structural coherence postulate:
  -- combine encoder soundness with `solver-result`.  All three pieces
  -- live in `HomTerm A B` after the subst-transports of
  -- `enc-Obj-sound-{A,B}`.

  no╧Г-discharge : f тЙИTerm g
  no╧Г-discharge = тЙИ-Term-trans (тЙИ-Term-sym sound-f)
                   (тЙИ-Term-trans subst-eq sound-g)
    where
      sP = enc-Obj-sound-A
      sQ = enc-Obj-sound-B

      sound-f : substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom nf)) тЙИTerm f
      sound-f = enc-Hom-sound-тЙИ-nf sP sQ

      sound-g : substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom ng)) тЙИTerm g
      sound-g = enc-Hom-sound-тЙИ-ng sP sQ

      -- Push solver-result through substтВВ: substтВВ is a congruence
      -- for тЙИTerm (with the same indices on both sides).
      substтВВ-cong-тЙИTerm
        : тИА {P Q P' Q'} (eP : P тЙб P') (eQ : Q тЙб Q')
          {h k : HomTerm P Q} тЖТ h тЙИTerm k
        тЖТ substтВВ HomTerm eP eQ h тЙИTerm substтВВ HomTerm eP eQ k
      substтВВ-cong-тЙИTerm refl refl eq = eq

      subst-eq
        : substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom nf))
        тЙИTerm substтВВ HomTerm sP sQ (Functor.FтВБ S.freeFunctor (enc-Hom ng))
      subst-eq = substтВВ-cong-тЙИTerm sP sQ solver-result

-- Discharge of the previously-postulated ╧Г-free coherence claim, now
-- via the module-internal `no╧Г-discharge`.

Structural-coherence-тЙИTerm-no╧Г
  : тИА {A B} {f g : HomTerm A B}
  тЖТ NoSigma f тЖТ NoSigma g
  тЖТ тЯк f тЯл тЙЕс┤┤ тЯк g тЯл
  тЖТ f тЙИTerm g
Structural-coherence-тЙИTerm-no╧Г {f = f} {g = g} nf ng _ = no╧Г-discharge nf ng

postulate
  Structural-coherence-тЙИTerm-╧Г
    : тИА {A B} {f g : HomTerm A B}
    тЖТ Structural f тЖТ Structural g
    тЖТ тЯк f тЯл тЙЕс┤┤ тЯк g тЯл
    тЖТ f тЙИTerm g

-- Dispatch: ╧Г-free ├Ч ╧Г-free goes to the Mac Lane sub-postulate; any
-- ╧Г-containing pair goes to the symmetric residual.
Structural-coherence-тЙИTerm
  : тИА {A B} {f g : HomTerm A B}
  тЖТ Structural f тЖТ Structural g
  тЖТ тЯк f тЯл тЙЕс┤┤ тЯк g тЯл
  тЖТ f тЙИTerm g
Structural-coherence-тЙИTerm sf sg iso with HasSigma? sf | HasSigma? sg
... | injтВБ nf | injтВБ ng = Structural-coherence-тЙИTerm-no╧Г nf ng iso
... | _       | _       = Structural-coherence-тЙИTerm-╧Г   sf sg iso

--------------------------------------------------------------------------------
-- Derived: lift `Structural-coherence-тЙИTerm` through `bridge` and
-- `decode-roundtrip-rel` to the original `decode-rel`-shaped lemma.
--
-- The derivation is purely categorical (no further postulates): the
-- `bridge`-wrapping is a congruence with respect to `_тЙИTerm_`, and
-- `decode-rel f тЙИTerm bridge f` for every `f` by `decode-roundtrip-rel`.

private
  open import Categories.Category using (Category)
  module FM = Category FreeMonoidal
  open FM.HomReasoning

  -- `bridge` is a congruence for `_тЙИTerm_`.  Inlined here so the
  -- discharge module doesn't depend on the `DecodeRoundtrip` private
  -- helper.
  bridge-resp-тЙИTerm
    : тИА {A B} {f g : HomTerm A B}
    тЖТ f тЙИTerm g тЖТ bridge f тЙИTerm bridge g
  bridge-resp-тЙИTerm fтЙИg = reflтЯйтИШтЯи fтЙИg тЯйтИШтЯиrefl

Structural-coherence
  : тИА {A B} {f g : HomTerm A B}
  тЖТ Structural f тЖТ Structural g
  тЖТ тЯк f тЯл тЙЕс┤┤ тЯк g тЯл
  тЖТ decode-rel f тЙИTerm decode-rel g
Structural-coherence {f = f} {g = g} sf sg iso = begin
  decode-rel f   тЙИтЯи decode-roundtrip-rel f тЯй
  bridge f       тЙИтЯи bridge-resp-тЙИTerm (Structural-coherence-тЙИTerm sf sg iso) тЯй
  bridge g       тЙИтЯи decode-roundtrip-rel g тЯи
  decode-rel g   тИО

--------------------------------------------------------------------------------
-- Discharge the original postulate.
--
-- `Atomic f` + `nE тЯк f тЯл тЙб 0` тЗТ `Structural f` (rules out `Agen`).
-- For the atomic shapes routed into the `тАж-0E` case from
-- `AtomicCompound.dispatch-structural`, the atomic-side edge count is
-- 0 by construction (see `nE-{id,╬╗тЗТ,╬╗тЗР,╧БтЗТ,╧БтЗР,╬▒тЗТ,╬▒тЗР,╧Г}` there) тАФ we
-- recover that here by case-splitting on the `Atomic` witness rather
-- than threading the edge-count proof through the API.

-- The originally-postulated lemma.  Note: the `Atomic f` hypothesis
-- combined with the dispatch from `AtomicCompound.dispatch-structural`
-- guarantees that `f` is *not* `Agen` (the Agen branch routes to
-- `decode-rel-resp-тЙЕс┤┤-Agen-compound-1E` instead).  We extract a
-- `Structural f` witness by case-analysis on `Atomic f`, where the
-- `Agen` branch is dismissed via the iso witness's edge-count
-- transport (a `Fin 1 тЖФ Fin 0` contradiction).

-- The discharge of `decode-rel-resp-тЙЕс┤┤-atomic-compound-0E`.  Note we
-- *drop* the redundant `Compound g` hypothesis: under
-- `nE тЯк g тЯл тЙб 0`, the `Compound g` argument carries no information
-- beyond the boundary types, since `Structural g` is recovered from
-- the edge-count witness alone (see `nE-0тЖТStructural`).  Dropping it
-- breaks an otherwise-circular import between `AtomicCompound.agda`
-- (which defines `Compound`) and this module.  The caller in
-- `AtomicCompound.agda` ignores the redundant argument when wiring up.

decode-rel-resp-тЙЕс┤┤-atomic-compound-0E
  : тИА {A B} {f g : HomTerm A B}
  тЖТ Atomic f
  тЖТ nE тЯк g тЯл тЙб 0
  тЖТ тЯк f тЯл тЙЕс┤┤ тЯк g тЯл
  тЖТ decode-rel f тЙИTerm decode-rel g
decode-rel-resp-тЙЕс┤┤-atomic-compound-0E {f = f} {g = g} af g-nEтЙб0 iso =
  Structural-coherence
    (atomicтЖТstructural af)
    (nE-0тЖТStructural g g-nEтЙб0)
    iso
  where
    -- The `Agen` branch of `Atomic f` is incompatible with
    -- `тЯк f тЯл тЙЕс┤┤ тЯк g тЯл` when `nE тЯк g тЯл тЙб 0`: the iso induces a
    -- bijection `Fin 1 тЖФ Fin 0`, which is absurd.  We discharge it by
    -- routing `╧И : Fin (nE тЯк Agen _ тЯл) тЖТ Fin (nE тЯк g тЯл)` and then
    -- transporting along `nE тЯк g тЯл тЙб 0`.
    open import Data.Fin using (Fin; zero)
    open import Relation.Binary.PropositionalEquality using (subst; sym)

    Fin-zero-empty : Fin 0 тЖТ тКе
    Fin-zero-empty ()

    -- In the `Agen` branch of `Atomic f`, the original `iso :
    -- тЯк f тЯл тЙЕс┤┤ тЯк g тЯл` becomes `тЯк Agen h тЯл тЙЕс┤┤ тЯк g тЯл` (with
    -- `nE тЯк Agen h тЯл тЙб 1`), so `╧И zero : Fin (nE тЯк g тЯл) = Fin 0`.
    atomicтЖТstructural : Atomic f тЖТ Structural f
    atomicтЖТstructural (atomic-Agen h) =
      тКе-elim (Fin-zero-empty (subst Fin g-nEтЙб0 (_тЙЕс┤┤_.╧И iso zero)))
    atomicтЖТstructural atomic-id        = structural-id
    atomicтЖТstructural atomic-╬╗тЗТ        = structural-╬╗тЗТ
    atomicтЖТstructural atomic-╬╗тЗР        = structural-╬╗тЗР
    atomicтЖТstructural atomic-╧БтЗТ        = structural-╧БтЗТ
    atomicтЖТstructural atomic-╧БтЗР        = structural-╧БтЗР
    atomicтЖТstructural atomic-╬▒тЗТ        = structural-╬▒тЗТ
    atomicтЖТstructural atomic-╬▒тЗР        = structural-╬▒тЗР
    atomicтЖТstructural (atomic-╧Г тжГ s тжД) = structural-╧Г тжГ s тжД
