-- The `Structural` predicate: "no `Agen` subterm anywhere".

data Structural : тИА {A B} тЖТ HomTerm A B тЖТ Set where
  structural-id : тИА {A} тЖТ Structural (id {A})
  structural-╬╗тЗТ : тИА {A} тЖТ Structural (╬╗тЗТ {A})
  structural-╬╗тЗР : тИА {A} тЖТ Structural (╬╗тЗР {A})
  structural-╧БтЗТ : тИА {A} тЖТ Structural (╧БтЗТ {A})
  structural-╧БтЗР : тИА {A} тЖТ Structural (╧БтЗР {A})
  structural-╬▒тЗТ : тИА {A B C} тЖТ Structural (╬▒тЗТ {A} {B} {C})
  structural-╬▒тЗР : тИА {A B C} тЖТ Structural (╬▒тЗР {A} {B} {C})
  structural-╧Г  : тИА {A B} тжГ s : Symm тЙд Symm тжД
                тЖТ Structural (╧Г {A = A} {B = B} тжГ s тжД)
  structural-тИШ  : тИА {A B C} {h : HomTerm B C} {k : HomTerm A B}
                тЖТ Structural h тЖТ Structural k
                тЖТ Structural (h тИШ k)
  structural-тКЧ  : тИА {A B C D} {h : HomTerm A B} {k : HomTerm C D}
                тЖТ Structural h тЖТ Structural k
                тЖТ Structural (h тКЧтВБ k)

--------------------------------------------------------------------------------
-- `NoSigma`: predicate "no `╧Г` subterm anywhere".  Strictly stronger
-- than `Structural` (which allows ╧Г); morphisms satisfying `NoSigma`
-- live in the Mac Lane fragment, where coherence is fully constructive
-- via `Categories.MonoidalCoherence.Solver.solveM`.

data NoSigma : тИА {A B} тЖТ HomTerm A B тЖТ Set where
  nosigma-id : тИА {A} тЖТ NoSigma (id {A})
  nosigma-╬╗тЗТ : тИА {A} тЖТ NoSigma (╬╗тЗТ {A})
  nosigma-╬╗тЗР : тИА {A} тЖТ NoSigma (╬╗тЗР {A})
  nosigma-╧БтЗТ : тИА {A} тЖТ NoSigma (╧БтЗТ {A})
  nosigma-╧БтЗР : тИА {A} тЖТ NoSigma (╧БтЗР {A})
  nosigma-╬▒тЗТ : тИА {A B C} тЖТ NoSigma (╬▒тЗТ {A} {B} {C})
  nosigma-╬▒тЗР : тИА {A B C} тЖТ NoSigma (╬▒тЗР {A} {B} {C})
  nosigma-тИШ  : тИА {A B C} {h : HomTerm B C} {k : HomTerm A B}
             тЖТ NoSigma h тЖТ NoSigma k
             тЖТ NoSigma (h тИШ k)
  nosigma-тКЧ  : тИА {A B C D} {h : HomTerm A B} {k : HomTerm C D}
             тЖТ NoSigma h тЖТ NoSigma k
             тЖТ NoSigma (h тКЧтВБ k)

NoSigmaтЖТStructural : тИА {A B} {f : HomTerm A B} тЖТ NoSigma f тЖТ Structural f
NoSigmaтЖТStructural nosigma-id      = structural-id
NoSigmaтЖТStructural nosigma-╬╗тЗТ      = structural-╬╗тЗТ
NoSigmaтЖТStructural nosigma-╬╗тЗР      = structural-╬╗тЗР
NoSigmaтЖТStructural nosigma-╧БтЗТ      = structural-╧БтЗТ
NoSigmaтЖТStructural nosigma-╧БтЗР      = structural-╧БтЗР
NoSigmaтЖТStructural nosigma-╬▒тЗТ      = structural-╬▒тЗТ
NoSigmaтЖТStructural nosigma-╬▒тЗР      = structural-╬▒тЗР
NoSigmaтЖТStructural (nosigma-тИШ h k) = structural-тИШ (NoSigmaтЖТStructural h)
                                                   (NoSigmaтЖТStructural k)
NoSigmaтЖТStructural (nosigma-тКЧ h k) = structural-тКЧ (NoSigmaтЖТStructural h)
                                                   (NoSigmaтЖТStructural k)

-- Decide whether a structural term contains at least one `╧Г`.
HasSigma? : тИА {A B} {f : HomTerm A B} тЖТ Structural f тЖТ NoSigma f тКО тКд
HasSigma? structural-id        = injтВБ nosigma-id
HasSigma? structural-╬╗тЗТ        = injтВБ nosigma-╬╗тЗТ
HasSigma? structural-╬╗тЗР        = injтВБ nosigma-╬╗тЗР
HasSigma? structural-╧БтЗТ        = injтВБ nosigma-╧БтЗТ
HasSigma? structural-╧БтЗР        = injтВБ nosigma-╧БтЗР
HasSigma? structural-╬▒тЗТ        = injтВБ nosigma-╬▒тЗТ
HasSigma? structural-╬▒тЗР        = injтВБ nosigma-╬▒тЗР
HasSigma? structural-╧Г         = injтВВ tt
HasSigma? (structural-тИШ sh sk) with HasSigma? sh | HasSigma? sk
... | injтВБ nh | injтВБ nk = injтВБ (nosigma-тИШ nh nk)
... | _       | _       = injтВВ tt
HasSigma? (structural-тКЧ sh sk) with HasSigma? sh | HasSigma? sk
... | injтВБ nh | injтВБ nk = injтВБ (nosigma-тКЧ nh nk)
... | _       | _       = injтВВ tt

--------------------------------------------------------------------------------
-- Atomic structural constructors are structural.  (The `Agen` atomic
-- constructor is excluded тАФ it has `nE тЙб 1` and is handled separately.)

Atomic-non-AgenтЖТStructural
  : тИА {A B} {f : HomTerm A B}
  тЖТ Atomic f тЖТ nE тЯк f тЯл тЙб 0 тЖТ Structural f
Atomic-non-AgenтЖТStructural (atomic-Agen _)   ()
Atomic-non-AgenтЖТStructural atomic-id         _ = structural-id
Atomic-non-AgenтЖТStructural atomic-╬╗тЗТ         _ = structural-╬╗тЗТ
Atomic-non-AgenтЖТStructural atomic-╬╗тЗР         _ = structural-╬╗тЗР
Atomic-non-AgenтЖТStructural atomic-╧БтЗТ         _ = structural-╧БтЗТ
Atomic-non-AgenтЖТStructural atomic-╧БтЗР         _ = structural-╧БтЗР
Atomic-non-AgenтЖТStructural atomic-╬▒тЗТ         _ = structural-╬▒тЗТ
Atomic-non-AgenтЖТStructural atomic-╬▒тЗР         _ = structural-╬▒тЗР
Atomic-non-AgenтЖТStructural (atomic-╧Г тжГ s тжД)  _ = structural-╧Г тжГ s тжД

--------------------------------------------------------------------------------
-- Main syntactic lemma: a 0-edge HomTerm is structural.
--
-- Proceeds by induction on `g`.  For atomic constructors, route via
-- `Atomic-non-AgenтЖТStructural` (and explicitly rule out `Agen`).  For
-- compound constructors, split the additive 0 into both summands.

nE-0тЖТStructural
  : тИА {A B} (g : HomTerm A B) тЖТ nE тЯк g тЯл тЙб 0 тЖТ Structural g
nE-0тЖТStructural (Agen _)              ()
nE-0тЖТStructural id                    _ = structural-id
nE-0тЖТStructural ╬╗тЗТ                    _ = structural-╬╗тЗТ
nE-0тЖТStructural ╬╗тЗР                    _ = structural-╬╗тЗР
nE-0тЖТStructural ╧БтЗТ                    _ = structural-╧БтЗТ
nE-0тЖТStructural ╧БтЗР                    _ = structural-╧БтЗР
nE-0тЖТStructural ╬▒тЗТ                    _ = structural-╬▒тЗТ
nE-0тЖТStructural ╬▒тЗР                    _ = structural-╬▒тЗР
nE-0тЖТStructural (╧Г тжГ s тжД)             _ = structural-╧Г тжГ s тжД
nE-0тЖТStructural (h тИШ k) g-nEтЙб0 =
  -- `nE тЯк h тИШ k тЯл = nE тЯк k тЯл + nE тЯк h тЯл` definitionally (see `nE-тИШ`
  -- in AtomicCompound.agda тАФ note the order: it's `nE k + nE h`).
  structural-тИШ
    (nE-0тЖТStructural h (m+nтЙб0тЗТnтЙб0 (nE тЯк k тЯл) g-nEтЙб0))
    (nE-0тЖТStructural k (m+nтЙб0тЗТmтЙб0 (nE тЯк k тЯл) g-nEтЙб0))
nE-0тЖТStructural (h тКЧтВБ k) g-nEтЙб0 =
  structural-тКЧ
    (nE-0тЖТStructural h (m+nтЙб0тЗТmтЙб0 (nE тЯк h тЯл) g-nEтЙб0))
    (nE-0тЖТStructural k (m+nтЙб0тЗТnтЙб0 (nE тЯк h тЯл) g-nEтЙб0))

